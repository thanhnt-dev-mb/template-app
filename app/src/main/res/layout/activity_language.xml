<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.merryblue.baseapplication.ui.onboard.language.LanguageViewModel"
            />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="#F3F4F6"
        >

        <LinearLayout
            android:id="@+id/topBarLayout"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            app:layout_constraintTop_toTopOf="parent"
            android:paddingTop="24dp"
            android:orientation="horizontal"
            android:background="@color/white"
            >

            <ImageView
                android:id="@+id/backBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_left"
                android:layout_marginStart="4dp"
                android:layout_gravity="center_vertical"
                android:visibility="gone"
                android:scaleType="center"
                tools:visibility="visible"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="@string/select_language"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/toolbarTitleColor"
                android:background="@color/transparent"
                />

            <TextView
                android:id="@+id/nextBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                app:fontFamily="@font/roboto_medium"
                android:textSize="14sp"
                android:text="@string/next"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:paddingVertical="4dp"
                android:background="@drawable/ripple_round_6"
                android:backgroundTint="@color/colorPrimary"
                />
        </LinearLayout>

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/topHandView"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:layout_constraintTop_toBottomOf="@+id/topBarLayout"
            app:layout_constraintEnd_toEndOf="@+id/topBarLayout"
            android:layout_marginEnd="18dp"
            android:translationY="-32dp"
            app:lottie_loop="true"
            android:elevation="8dp"
            android:visibility="gone"
            tools:visibility="visible"
            />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/languageRv"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="4dp"
            app:layout_constraintTop_toBottomOf="@+id/topBarLayout"
            app:layout_constraintBottom_toTopOf="@+id/layoutCard"
            tools:listitem="@layout/item_language"
            />

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/handleView"
            android:layout_width="66dp"
            android:layout_height="66dp"
            app:layout_constraintTop_toTopOf="@+id/languageRv"
            app:layout_constraintEnd_toEndOf="@+id/languageRv"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="16dp"
            app:lottie_loop="true"
            android:elevation="8dp"
            android:visibility="gone"
            tools:visibility="visible"
            />

        <androidx.cardview.widget.CardView
            android:id="@+id/layoutCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginVertical="8dp"
            android:layout_marginHorizontal="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:elevation="12dp"
            android:gravity="bottom"
            app:cardCornerRadius="10dp"
            app:cardElevation="12dp"
            app:cardPreventCornerOverlap="false"
            android:layout_gravity="center_horizontal"
            android:background="@color/white"
            >

            <FrameLayout
                android:id="@+id/adsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"/>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>