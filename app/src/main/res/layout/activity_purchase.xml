<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.merryblue.baseapplication.ui.iap.PurchaseViewModel" />

        <variable
            name="host"
            type="com.merryblue.baseapplication.ui.iap.PurchaseActivity" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="@color/color4B5563"
        >

        <ImageView
            android:id="@+id/bannerImg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/img_privacy_small"
            android:adjustViewBounds="true"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/closeBtn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_premium_close"
            android:layout_marginStart="4dp"
            android:layout_marginTop="26dp"
            android:scaleType="center"
            android:background="?selectableItemBackgroundBorderless" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@+id/bannerImg"
            app:layout_constraintBottom_toTopOf="@+id/bottomLayout"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:textSize="24sp"
                    app:fontFamily="@font/roboto_bold"
                    android:textColor="#F59E0B"
                    tools:text="@string/txt_upgrade_to"
                    android:text="@{viewModel.uiState.headerTitle(context)}"
                    android:layout_marginVertical="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_offer_1"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:drawablePadding="8dp"
                    app:drawableStartCompat="@drawable/ic_premium_tick"
                    app:fontFamily="@font/roboto_regular"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                     />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_offer_2"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:drawablePadding="8dp"
                    app:drawableStartCompat="@drawable/ic_premium_tick"
                    app:fontFamily="@font/roboto_regular"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_offer_3"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:drawablePadding="8dp"
                    app:drawableStartCompat="@drawable/ic_premium_tick"
                    app:fontFamily="@font/roboto_regular"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/yearlyPackage"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:layout_width="match_parent"
                    android:layout_height="102dp"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="24dp"
                    isEnabled="@{viewModel.uiState.yearlyEnable}"
                    android:background="@drawable/bg_premium_package"
                    isSelected="@{viewModel.uiState.yearly}"
                    onSingleClick="@{v -> viewModel.onSelectPlan(true)}"
                    >

                    <ImageView
                        android:id="@+id/yearlyIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:adjustViewBounds="true"
                        android:src="@drawable/ic_premium_selector"
                        isSelected="@{viewModel.uiState.yearly}"
                        />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/yearlyIcon"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        >

                        <TextView
                            android:id="@+id/yearlyTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_premium_yearly_package"
                            android:textSize="16sp"
                            app:fontFamily="@font/roboto_regular"
                            />

                        <TextView
                            android:id="@+id/yearlyPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:layout_marginTop="4dp"
                            android:textColor="#1F2937"
                            tools:text="$21.50/Year"
                            android:layout_marginVertical="4dp"
                            app:fontFamily="@font/roboto_regular"
                            />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/white"
                            android:text="@string/txt_start_free_trial"
                            android:background="@drawable/ripple_round_4"
                            android:backgroundTint="#44BC26"
                            android:clickable="false"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            app:fontFamily="@font/roboto_regular"
                            tools:visibility="visible"
                            isGone="@{!viewModel.uiState.yearlyTrial}"
                            />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/monthlyPackage"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:layout_width="match_parent"
                    android:layout_height="78dp"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="24dp"
                    isSelected="@{viewModel.uiState.monthly}"
                    android:background="@drawable/bg_premium_package"
                    onSingleClick="@{v -> viewModel.onSelectPlan(false)}"
                    >

                    <ImageView
                        android:id="@+id/monthlyIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:adjustViewBounds="true"
                        android:src="@drawable/ic_premium_selector"
                        isSelected="@{viewModel.uiState.monthly}"
                        />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/monthlyIcon"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        >

                        <TextView
                            android:id="@+id/monthTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_premium_monthly_package"
                            android:textSize="16sp"
                            app:fontFamily="@font/roboto_regular"
                            />

                        <TextView
                            android:id="@+id/monthlyPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:layout_marginTop="4dp"
                            android:textColor="#1F2937"
                            app:fontFamily="@font/roboto_regular"
                            tools:text="$2.50/Month"
                            />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/bottomLayout"
            android:layout_width="match_parent"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            android:paddingBottom="24dp"
            android:background="#101827"
            android:layout_height="wrap_content" >

            <TextView
                android:id="@+id/upgradeBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginVertical="12dp"
                tools:text="@string/txt_try_free"
                android:text="@{viewModel.uiState.confirmTitle(context)}"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/ripple_round_100"
                android:gravity="center"
                android:textSize="16sp"
                app:fontFamily="@font/roboto_medium"
                android:textColor="@color/white"
                />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:text="@string/txt_try_free_trial_desc"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="@color/white"
                />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>