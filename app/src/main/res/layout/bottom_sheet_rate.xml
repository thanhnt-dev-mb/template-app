<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:behavior_hideable="false"
        android:gravity="center_horizontal"
        android:background="@drawable/bg_top_rounded_24"
        app:layout_behavior="@string/bottom_sheet_behavior"
        >
        <com.google.android.material.bottomsheet.BottomSheetDragHandleView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imageEmoji"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:padding="4dp"
            app:srcCompat="@drawable/ic_5_star" />

        <LinearLayout
            android:id="@+id/rdgRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            >

            <CheckBox
                android:id="@+id/rdbStar1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ic_star_selector"
                android:button="@null" />

            <CheckBox
                style="@style/ClickAnimation"
                android:id="@+id/rdbStar2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/ic_star_selector"
                android:button="@null" />

            <CheckBox
                style="@style/ClickAnimation"
                android:id="@+id/rdbStar3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ic_star_selector"
                android:button="@null" />

            <CheckBox
                style="@style/ClickAnimation"
                android:id="@+id/rdbStar4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/ic_star_selector"
                android:button="@null" />

            <CheckBox
                style="@style/ClickAnimation"
                android:id="@+id/rdbStar5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ic_star_selector"
                android:button="@null" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvFeedbackTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/do_you_like_the_app"
            android:textColor="@android:color/black"
            android:textSize="@dimen/text_size_16"
            app:fontFamily="@font/roboto_bold"
            />

        <TextView
            android:id="@+id/tvRateLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:text="@string/txt_rating_description"
            android:textSize="@dimen/text_size_14"
            app:fontFamily="@font/roboto_regular"
            />

        <TextView
            android:id="@+id/btnOk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="38dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/btn_send_state"
            android:textColor="@drawable/btn_color_state"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="@string/text_send"
            android:textSize="@dimen/text_size_14"
            app:fontFamily="@font/roboto_medium"
            />
    </LinearLayout>
</layout>
