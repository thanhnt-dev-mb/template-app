<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

  <data>
    <variable
        name="data"
        type="com.merryblue.baseapplication.coredata.model.IntroModel"
        />
  </data>

  <androidx.constraintlayout.widget.ConstraintLayout
      android:id="@+id/contentLayout"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:background="@color/white"
      >

    <ImageView
        android:id="@+id/ivIntro"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        app:imgRes="@{data.mainImg}"
        tools:src="@drawable/image_intro1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@color/white"
        android:orientation="vertical">

      <TextView
          android:id="@+id/nextBtn"
          android:layout_width="match_parent"
          android:layout_height="36dp"
          app:layout_constraintTop_toTopOf="@+id/layoutDot"
          app:layout_constraintBottom_toBottomOf="@+id/layoutDot"
          app:layout_constraintEnd_toEndOf="parent"
          android:layout_marginHorizontal="16dp"
          android:text="@{data.pageIndex == 3 ? @string/txt_started : @string/next}"
          tools:text="@string/txt_started"
          android:textSize="16sp"
          android:gravity="center"
          app:fontFamily="@font/roboto_medium"
          android:background="@drawable/ripple_border_round_100"
          android:backgroundTint="#F3F4F6"
          android:layout_marginVertical="16dp"
          android:textColor="#EC4899" />

      <androidx.cardview.widget.CardView
          android:id="@+id/layoutCard"
          android:layout_width="match_parent"
          app:layout_constraintBottom_toBottomOf="parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="8dp"
          android:clipChildren="false"
          android:clipToPadding="false"
          android:gravity="bottom"
          app:cardPreventCornerOverlap="false"
          >
        <FrameLayout
            android:id="@+id/adsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="90dp"
            />
      </androidx.cardview.widget.CardView>
    </LinearLayout>

  </androidx.constraintlayout.widget.ConstraintLayout>

</layout>