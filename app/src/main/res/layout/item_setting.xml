<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable
            name="data"
            type="com.merryblue.baseapplication.coredata.model.Setting" />
    </data>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:background="#F3F4F6"
        android:paddingHorizontal="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/contentLayout"
            android:foreground="?android:attr/selectableItemBackground"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            >

            <ImageView
                android:id="@+id/flagImage"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:adjustViewBounds="true"
                android:background="@drawable/ripple_round_4"
                android:backgroundTint="#E5E7EB"
                app:imgRes="@{data.resIcon}"
                android:scaleType="center"
                app:tint="@color/toolbarTitleColor"
                />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/flagImage"
                app:layout_constraintEnd_toStartOf="@+id/rightLayout"
                android:layout_marginEnd="16dp"
                app:layout_constraintTop_toTopOf="parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/languageTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@{data.getTitle(context)}"
                    android:textSize="@dimen/text_size14"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/toolbarTitleColor"
                    />

                <TextView
                    android:id="@+id/languageSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@{data.value}"
                    isGone="@{!data.hasValue()}"
                    android:textSize="@dimen/text_size12"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="#4B5563"
                    tools:text="English"
                    android:layout_marginTop="4dp"
                    />

            </LinearLayout>

            <FrameLayout
                android:id="@+id/rightLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                isGone="@{!data.hasRightLayout}"
                android:layout_marginStart="24dp"
                android:clickable="false"
                >

                <ImageView
                    android:id="@+id/switchBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    isGone="@{data.rightIcon == 0}"
                    imgRes="@{data.rightIcon}"
                    android:scaleType="center"
                    android:layout_gravity="end"
                    android:background="?android:attr/selectableItemBackground"
                    />

                <TextView
                    android:id="@+id/dropDownBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:textSize="12sp"
                    android:textColor="#3B82F6"
                    android:text="@{data.value}"
                    android:layout_gravity="end"
                    android:gravity="center_vertical"
                    app:drawableEndCompat="@drawable/ic_down"
                    android:drawablePadding="4dp"
                    android:paddingVertical="4dp"
                    android:paddingEnd="4dp"
                    android:paddingStart="44dp"
                    isGone="@{data.rightIcon != 0}"
                    android:background="?android:attr/selectableItemBackground"
                    />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >
            <View
                android:id="@+id/footerView"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="@color/toolbarTitleColor"
                />
        </FrameLayout>
    </LinearLayout>

</layout>