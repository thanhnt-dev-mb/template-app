<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:paddingVertical="8dp"
    android:paddingHorizontal="16dp"
    android:maxHeight="300dp"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/normalPHIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="#99D9D9D9"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/normalPHPreloadTv"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8dp"
        android:background="#99D9D9D9"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/normalPHTitle" />

    <TextView
        android:id="@+id/normalPHTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:background="#99D9D9D9"
        app:layout_constraintStart_toEndOf="@+id/normalPHIcon"
        app:layout_constraintTop_toTopOf="@+id/normalPHIcon"
        app:layout_constraintEnd_toStartOf="@+id/normalPHPreloadTv" />

    <TextView
        android:id="@+id/normalPHBody"
        android:ellipsize="end"
        android:maxLines="1"
        android:background="#99D9D9D9"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@+id/normalPHIcon"
        app:layout_constraintTop_toBottomOf="@+id/normalPHTitle" />

    <FrameLayout
        android:id="@+id/normalPHMediaContent"
        android:layout_width="0dp"
        android:layout_height="108dp"
        android:layout_marginTop="8dp"
        android:background="#99D9D9D9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/normalPHBody" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginVertical="8dp"
        android:background="#99D9D9D9"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/normalPHMediaContent"
        tools:layout_editor_absoluteX="8dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>